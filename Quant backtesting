        }
        .section-title { font-size: 2.25rem; font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
        .section-desc { color: var(--text-secondary); font-size: 1.05rem; max-width: 700px; }
        .hero {
            min-height: 100vh; display: flex; flex-direction: column;
            justify-content: center; padding-top: 64px;
        }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 0.5rem;
