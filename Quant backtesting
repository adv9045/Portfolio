        .repo-card {
            background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;
            padding: 1.75rem; display: flex; justify-content: space-between; align-items: flex-start;
            transition: all 0.3s; text-decoration: none; color: inherit;
        }
        .repo-card:hover { border-color: var(--accent-cyan); transform: translateX(8px); }
        .repo-info h4 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--accent-cyan); }
        .repo-info p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.75rem; }
        .repo-meta { display: flex; gap: 1rem; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-muted); }
        .repo-meta span { display: flex; align-items: center; gap: 0.35rem; }
        .repo-lang { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
