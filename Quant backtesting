        .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
        .metric { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; text-align: center; }
        .metric-value { font-family: 'JetBrains Mono', monospace; font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; }
        .metric-value.positive { color: var(--accent-green); }
        .metric-value.negative { color: var(--accent-rose); }
        .metric-value.neutral { color: var(--accent-cyan); }
        .metric-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }
        .strategy-grid { display: grid; gap: 2rem; }
